# PostgreSQL (Docker on port 5433 — does NOT touch your local Postgres on 5432)
DATABASE_URL=postgresql://skillbridge:skillbridge123@localhost:5433/skillbridge

# Per-service database URLs (each uses its own schema)
USER_SERVICE_DATABASE_URL=postgresql://skillbridge:skillbridge123@localhost:5433/skillbridge?schema=users
GIG_SERVICE_DATABASE_URL=postgresql://skillbridge:skillbridge123@localhost:5433/skillbridge?schema=gigs
ORDER_SERVICE_DATABASE_URL=postgresql://skillbridge:skillbridge123@localhost:5433/skillbridge?schema=orders
COMM_SERVICE_DATABASE_URL=postgresql://skillbridge:skillbridge123@localhost:5433/skillbridge?schema=communication

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Service Ports
API_GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
GIG_SERVICE_PORT=3002
ORDER_SERVICE_PORT=3003
COMM_SERVICE_PORT=3004

# Service URLs (used by API Gateway)
USER_SERVICE_URL=http://localhost:3001
GIG_SERVICE_URL=http://localhost:3002
ORDER_SERVICE_URL=http://localhost:3003
COMM_SERVICE_URL=http://localhost:3004

# Frontend
FRONTEND_URL=http://localhost:4200
